{
  "name": "line-secretary",
  "description": "Personal LINE AI secretary — remember, remind, todo, calendar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "clean": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\"",
    "rebuild": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:migrations": "tsx scripts/check-migration-parity.ts",
    "check:schedules": "tsx scripts/check-schedule-health.ts",
    "baseline": "tsx scripts/baseline-report.ts",
    "eval:routing": "tsx scripts/eval-routing-live.ts",
    "eval:rag": "tsx scripts/eval-rag-live.ts",
    "audit:wcag": "tsx scripts/audit-wcag.ts",
    "smoke:canary": "tsx scripts/canary-smoke.ts",
    "audit:security": "tsx scripts/security-audit.ts"
  },
  "dependencies": {
    "@line/bot-sdk": "^11.1.0",
    "@line/liff": "2.29.1",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "@upstash/qstash": "^2.11.1",
    "@upstash/redis": "^1.38.0",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "googleapis": "^173.0.0",
    "nanoid": "^5.1.16",
    "next": "16.2.10",
    "openai": "^6.45.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "axe-core": "^4.12.1",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }

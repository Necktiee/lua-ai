# ───────────────────────────────────────────────────────────
# Lekha — Personal LINE Secretary. Copy → .env.local แล้วกรอก
# ───────────────────────────────────────────────────────────

# App
NODE_ENV=development
# ตอน dev = tunnel URL (cloudflared), ตอน prod = https://yourdomain
APP_BASE_URL=https://example.trycloudflare.com
# whitelist LINE userId ที่อนุญาตใช้ bot (คั่นด้วย ,) — ป้องกันคนอื่นยิง
LINE_USER_WHITELIST=
# Single-owner mode (optional): ทุกข้อมูลถูก attribute เข้า userId นี้หมด ไม่ว่าจะแชท/ล็อกอินด้วยบัญชี LINE ไหน
OWNER_LINE_USER_ID=

# LINE
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Supabase
# dev = local docker (http://127.0.0.1:54321), prod = https://xxx.supabase.co
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Upstash QStash (scheduled reminders)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ป้องกัน /api/cron/poll (optional แต่แนะนำ)
CRON_SECRET=

# Google Calendar OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/cal/callback

# Web search — Tavily (https://tavily.com) — optional, powers goal.search
TAVILY_API_KEY=

# LIFF dashboard — LINE Login channel (สร้างใต้ provider เดียวกับ Messaging API channel)
# LIFF_ID จากแท็บ LIFF ในตัว channel, LIFF_CHANNEL_ID จากแท็บ Basic settings
LIFF_ID=
LIFF_CHANNEL_ID=
NEXT_PUBLIC_LIFF_ID=
# secret เซ็น session cookie ของ dashboard (fallback ไปที่ LINE_CHANNEL_SECRET ถ้าไม่ตั้ง)
SESSION_SECRET=
# AES-256 key for Google OAuth tokens at rest (32-byte hex/base64, or passphrase). Required in prod.
TOKEN_ENCRYPTION_KEY=

# ─── LLM pools (comma-separated, ใส่ได้หลาย key) ───
GEMINI_API_KEYS=
MISTRAL_API_KEYS=
THAILLM_API_KEYS=
OPENROUTER_API_KEYS=

# Provider endpoints (override ได้)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_LITE=gemini-2.5-flash-lite

MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest

THAILLM_BASE_URL=https://api.openthaigpt.org/v1
THAILLM_MODEL=openthaigpt-1.0.0-8b-chat

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=baai/bge-m3

# Routing
# Note: thaillm ไม่ OpenAI-compatible โดยตรง — ใช้ผ่าน LiteLLM proxy ถ้าต้องการ
LLM_PRIMARY_PROVIDER=gemini
LLM_FALLBACK_ORDER=gemini,mistral
LLM_EMBEDDING_PROVIDER=openrouter
LLM_EMBEDDING_MODEL=baai/bge-m3
